{
  "name": "agent-continuity",
  "version": "0.1.0",
  "description": "Durable checkpoint and resume state for coding agents, backed by Absurd and PostgreSQL.",
  "type": "module",
  "bin": {
    "continuity": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "integrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "agent",
    "checkpoint",
    "continuity",
    "absurd",
    "postgres",
    "opencode",
    "claude"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "absurd-sdk": "^0.4.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "typescript": "^5.9.3"
  }
}
